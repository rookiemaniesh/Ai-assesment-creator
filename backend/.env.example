PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/veda-ai
# Upstash URL format (get from Upstash dashboard → Connect → ioredis)
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6380
AI_SERVICE_URL=http://localhost:8000
NODE_ENV=development
# JWT signing secret (min 16 chars). Change in production.
JWT_SECRET=your-long-random-secret-at-least-16-chars
